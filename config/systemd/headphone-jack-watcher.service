[Unit]
Description=Headphone Jack Auto-Switch Watcher
After=audiophile-backend.service sound.target
Wants=audiophile-backend.service

[Service]
Type=simple
User=tysbox
Group=tysbox
ExecStart=/home/tysbox/HQ_Linux_Music_Player/backend/scripts/headphone_jack_watcher.sh
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
