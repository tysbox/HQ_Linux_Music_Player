# /etc/asound.conf の修正版
pcm.!default {
    type plug
    slave.pcm "bluealsa"
}

ctl.!default {
    type bluealsa
}

defaults.bluealsa.interface "hci0"
defaults.bluealsa.device "00:00:00:00:00:00"
defaults.bluealsa.profile "a2dp"
defaults.bluealsa.delay 20000
